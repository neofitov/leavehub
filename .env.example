# Copy this file to ".env" and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API.

# Public (safe to expose in the browser bundle):
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used ONLY by the local seed script (scripts/seed.js).
# This is the service_role key - it bypasses RLS. NEVER expose it in the
# frontend or commit the real value. Keep it in .env (git-ignored) only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
