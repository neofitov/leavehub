# Copy this file to ".env" and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API.

# Public (safe to expose in the browser bundle) — the "publishable" key:
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Used ONLY by the local seed script (scripts/seed.js).
# This is the "secret" key (sb_secret_...) — it bypasses RLS. NEVER expose it in
# the frontend or commit the real value. Keep it in .env (git-ignored) only.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx
